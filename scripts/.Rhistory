library(readr)
# Specify the directory where your GTF files are located
directory <- "C:/VL_Cobetia/data/NCBI/gtf"
# Get a list of GTF files in the directory
files <- list.files(directory, pattern = "\\.gtf$", full.names = TRUE)
# Create an empty list to store data frames
df_list <- list()
# Import each GTF file into a data frame and store it in the list
for (file in files) {
df_list[[file]] <- read_delim(file, delim = "\t", comment = "#", col_names = FALSE)
}
# Bind all data frames in the list into a single data frame
final_df <- do.call(rbind, df_list)
# Optionally, you can assign column names to the final data frame based on GTF specifications
# For example, if GTF columns are typically named V1, V2, V3, etc., you can do:
colnames(final_df) <- paste0("V", 1:ncol(final_df))
final_df
